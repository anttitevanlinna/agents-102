#!/usr/bin/env bash
# Tool-agnostic git pre-commit hook.
#
# Fires on every `git commit` regardless of which agent or tool initiated it
# (Claude Code, Codex, manual git, IDE integrations). When staged changes
# include any file under curriculum/prompts/**, prints the diff summary and
# requires explicit y/N confirmation from the human committer.
#
# Why: prompt-registry files are the canonical source of student-facing prompts.
# Edits to them must be deliberate. The Claude-Code-specific PreToolUse gate
# (.claude/hooks/prompt-edit-gate.sh) catches at write time within Claude
# Code; this hook is the second-line defence catching commits from any tool.
#
# Setup (run once per clone):
#   git config core.hooksPath .githooks
#
# Bypass for legitimate bulk operations:
#   SKIP_PROMPT_GATE=1 git commit ...

set -e

# Bypass
if [ "${SKIP_PROMPT_GATE:-0}" = "1" ]; then
    exit 0
fi

# Find staged changes under curriculum/prompts/ — registry only.
# Inline **Prompt** fenced blocks elsewhere (modules, exercises, lectures
# pre-migration) are NOT in scope; those remain protected by review.
staged=$(git diff --cached --name-only -- 'curriculum/prompts/**' 2>/dev/null || true)
if [ -z "$staged" ]; then
    exit 0
fi

# Region check (added 2026-05-18): per check_prompts.md rule 22 + rule 26 carve-out,
# the gate applies to the BODY of the prompt (what students paste). Frontmatter
# edits (between leading `---` markers) and maintainer-block edits (below
# `<!-- maintainer -->`) are NOT gated. Compare the body region of each staged
# prompt against HEAD; if no body region changed, skip confirmation.
if command -v python3 >/dev/null 2>&1; then
    body_changed=$(STAGED_FILES="$staged" python3 - <<'PYEOF'
import os, re, subprocess, sys

def body(content):
    fm = re.match(r'^---\n.*?\n---\n', content, re.DOTALL)
    fm_end = fm.end() if fm else 0
    mb_idx = content.find("<!-- maintainer -->")
    mb_start = mb_idx if mb_idx != -1 else len(content)
    return content[fm_end:mb_start]

staged = [f for f in os.environ.get("STAGED_FILES", "").splitlines() if f.strip()]

for fp in staged:
    try:
        new = subprocess.check_output(["git", "show", f":{fp}"], text=True)
    except subprocess.CalledProcessError:
        # Couldn't read staged version (deleted file). Gate to be safe.
        print(1); sys.exit(0)
    try:
        old = subprocess.check_output(["git", "show", f"HEAD:{fp}"], text=True, stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        # New file with no HEAD version. Gate.
        print(1); sys.exit(0)
    if body(old) != body(new):
        print(1); sys.exit(0)

print(0)
PYEOF
)
    if [ "$body_changed" = "0" ]; then
        exit 0
    fi
fi

# Inform the human and require confirmation. Commit hooks run in a non-tty
# context inside many GUIs / IDE clients — fall back to /dev/tty for the read.
echo "──────────────────────────────────────────────────────────────────────"
echo "Prompt registry change detected. Staged files under curriculum/prompts/:"
echo
git diff --cached --stat -- 'curriculum/prompts/**'
echo
echo "Diff summary:"
git diff --cached --shortstat -- 'curriculum/prompts/**'
echo
echo "Prompt edits ship to every student. Confirm before committing."
echo "(Bypass entire gate for batch ops: SKIP_PROMPT_GATE=1 git commit ...)"
echo "──────────────────────────────────────────────────────────────────────"

# Read confirmation from the controlling terminal so this works under VS Code
# / IntelliJ / etc. that disconnect stdin from /dev/tty by default.
if [ ! -t 0 ] && [ -e /dev/tty ]; then
    exec < /dev/tty
fi
printf "Proceed with commit? [y/N] "
read -r reply
case "$reply" in
    y|Y|yes|YES) exit 0 ;;
    *) echo "Commit aborted." >&2; exit 1 ;;
esac
