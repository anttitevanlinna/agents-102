#!/usr/bin/env bash
# Tool-agnostic git pre-commit hook.
#
# Fires on every `git commit` regardless of which agent or tool initiated it
# (Claude Code, Codex, manual git, IDE integrations). When staged changes
# include any file under curriculum/prompts/**, prints the diff summary and
# requires explicit y/N confirmation from the human committer.
#
# Why: prompt-registry files are the canonical source of student-facing prompts.
# Edits to them must be deliberate. The Claude-Code-specific PreToolUse gate
# (.claude/hooks/prompt-edit-gate.sh) catches at write time within Claude
# Code; this hook is the second-line defence catching commits from any tool.
#
# Setup (run once per clone):
#   git config core.hooksPath .githooks
#
# Bypass for legitimate bulk operations:
#   SKIP_PROMPT_GATE=1 git commit ...

set -e

# Bypass
if [ "${SKIP_PROMPT_GATE:-0}" = "1" ]; then
    exit 0
fi

# Find staged changes under curriculum/prompts/ — registry only.
# Inline **Prompt** fenced blocks elsewhere (modules, exercises, lectures
# pre-migration) are NOT in scope; those remain protected by review.
# Exclude README.md — maintainer-facing documentation, not a prompt entry;
# matches the README carve-out in .claude/hooks/prompt-edit-gate.sh so the
# two hook layers stay symmetric.
staged=$(git diff --cached --name-only -- 'curriculum/prompts/**' ':(exclude)curriculum/prompts/README.md' 2>/dev/null || true)
if [ -z "$staged" ]; then
    exit 0
fi

# Region check (added 2026-05-18): per check_prompts.md rule 22 + rule 26 carve-out,
# the gate applies to the BODY of the prompt (what students paste). Frontmatter
# edits (between leading `---` markers) and maintainer-block edits (below
# `<!-- maintainer -->`) are NOT gated. Compare the body region of each staged
# prompt against HEAD; if no body region changed, skip confirmation.
if command -v python3 >/dev/null 2>&1; then
    body_changed=$(STAGED_FILES="$staged" python3 - <<'PYEOF'
import os, re, subprocess, sys

def body(content):
    fm = re.match(r'^---\n.*?\n---\n', content, re.DOTALL)
    fm_end = fm.end() if fm else 0
    mb_idx = content.find("<!-- maintainer -->")
    mb_start = mb_idx if mb_idx != -1 else len(content)
    return content[fm_end:mb_start]

staged = [f for f in os.environ.get("STAGED_FILES", "").splitlines() if f.strip()]

for fp in staged:
    try:
        new = subprocess.check_output(["git", "show", f":{fp}"], text=True)
    except subprocess.CalledProcessError:
        # Couldn't read staged version (deleted file). Gate to be safe.
        print(1); sys.exit(0)
    try:
        old = subprocess.check_output(["git", "show", f"HEAD:{fp}"], text=True, stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        # New file with no HEAD version. Gate.
        print(1); sys.exit(0)
    if body(old) != body(new):
        print(1); sys.exit(0)

print(0)
PYEOF
)
    if [ "$body_changed" = "0" ]; then
        exit 0
    fi
fi

# Inform the human.
echo "──────────────────────────────────────────────────────────────────────"
echo "Prompt registry change detected. Staged files under curriculum/prompts/:"
echo
git diff --cached --stat -- 'curriculum/prompts/**'
echo
echo "Diff summary:"
git diff --cached --shortstat -- 'curriculum/prompts/**'
echo

# Card-approval bridge (added 2026-05-21): when the maintainer types
# `approve <prompt-key>` during a Claude Code card flow, Claude writes a
# marker at `.claude/prompt-approvals/<key>.confirmed`. The marker records
# the human's approval token in a durable form. If ALL staged prompt keys
# have fresh markers (< 1 hour old), skip the interactive confirm and
# consume the markers (one-shot). The card approval IS the gate clear;
# no separate y/N needed.
#
# Markers live under .claude/prompt-approvals/, which is gitignored by
# the existing `.claude/*` rule. Stale markers are ignored, not deleted.
APPROVAL_DIR=".claude/prompt-approvals"
APPROVAL_TTL_SECONDS=3600
all_approved=1
to_consume=""
missing_keys=""
while IFS= read -r staged_file; do
    [ -z "$staged_file" ] && continue
    key="$(basename "$staged_file" .md)"
    marker="$APPROVAL_DIR/$key.confirmed"
    if [ ! -f "$marker" ]; then
        all_approved=0
        missing_keys="$missing_keys $key"
        continue
    fi
    # macOS stat -f %m, GNU stat -c %Y; try both.
    marker_mtime=$(stat -f %m "$marker" 2>/dev/null || stat -c %Y "$marker" 2>/dev/null || echo 0)
    now=$(date +%s)
    age=$((now - marker_mtime))
    if [ "$age" -gt "$APPROVAL_TTL_SECONDS" ]; then
        all_approved=0
        missing_keys="$missing_keys $key(stale)"
        continue
    fi
    to_consume="$to_consume $marker"
done <<EOF
$staged
EOF

if [ "$all_approved" = "1" ] && [ -n "$to_consume" ]; then
    echo "All staged prompts have fresh card approvals — gate cleared."
    echo "Consuming markers:$to_consume"
    echo "──────────────────────────────────────────────────────────────────────"
    for m in $to_consume; do rm -f "$m"; done
    exit 0
fi

echo "Prompt edits ship to every student. Confirm before committing."
if [ "$all_approved" = "0" ]; then
    echo "(Missing or stale card approvals for:$missing_keys — fall back to interactive confirm.)"
fi
echo "(Bypass entire gate for batch ops: SKIP_PROMPT_GATE=1 git commit ...)"
echo "──────────────────────────────────────────────────────────────────────"

# Interactive confirmation. Preference: /dev/tty when stdin isn't a terminal
# (GUI clients / IDEs that disconnect stdin but keep the controlling
# terminal). Git disconnects stdin for hooks (sets it to /dev/null), so
# `echo y | git commit ...` does NOT work. /dev/tty is the only interactive
# channel — when unconnected (Claude Code, headless CI), abort with a clear
# message; the card-approval bridge above is the supported headless path.
#
# Probe /dev/tty in a subshell so the shell-level "Device not configured"
# error stays inside the subshell (2>/dev/null suppresses it there). A bare
# `: < /dev/tty 2>/dev/null` leaks the message because shell redirect errors
# print to the parent shell's fd 2, not the command's.
if [ ! -t 0 ]; then
    if ( exec < /dev/tty ) 2>/dev/null; then
        exec < /dev/tty
    fi
fi
printf "Proceed with commit? [y/N] "
if ! IFS= read -r reply; then
    echo
    echo "No confirmation channel available." >&2
    echo "Either run from a terminal with /dev/tty connected, or approve" >&2
    echo "each prompt via the Claude Code card flow (writes a marker to" >&2
    echo "  $APPROVAL_DIR/<key>.confirmed)" >&2
    exit 1
fi
case "$reply" in
    y|Y|yes|YES) exit 0 ;;
    *) echo "Commit aborted." >&2; exit 1 ;;
esac
